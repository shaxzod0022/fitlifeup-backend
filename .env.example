# JWT Authentication Configuration
# Required: Secret key for signing JWT tokens (minimum 32 characters required)
JWT_SECRET=your-super-secret-key-min-32-characters-long

# Optional: Access token expiration time (default: 15m)
# Examples: '15m', '1h', '30m'
JWT_ACCESS_EXPIRY=15m

# Optional: Refresh token expiration time (default: 7d)
# Examples: '7d', '30d', '14d'
JWT_REFRESH_EXPIRY=7d

# Optional: Bcrypt salt rounds for password hashing (default: 10, minimum: 10)
BCRYPT_SALT_ROUNDS=10

# Server Configuration
PORT=3000
